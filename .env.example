# Your Perplexity browser session cookies
PERPLEXITY_SESSION_TOKEN=paste-your-session-token-here
PERPLEXITY_CSRF_TOKEN=paste-your-csrf-token-here

# Optional: If you want to protect your API with a Bearer token
PERPLEXITY_API_KEY=

# Default model
# PERPLEXITY_SEARCH_MODEL=sonar
# PERPLEXITY_REASON_MODEL=sonar-reasoning

# Server
HOST=127.0.0.1
PORT=3000

# Timeouts (seconds)
SEARCH_TIMEOUT_SECS=30
REASON_TIMEOUT_SECS=120
RESEARCH_TIMEOUT_SECS=300
